---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Літопис — редактор документів">

  <!-- ══ HERO ══ -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-content fade-up">
      <div class="hero-badge">Настільний застосунок для Windows</div>
      <h1>Ручка — зброя писаря.<br/>Дозволь пальцям вижити!</h1>
      <p class="hero-sub">Litopys — офлайн-редактор твоїх журналів.<br class="br-d"/> Без підписок, без хмар, без болі в руках — без зайвого.</p>
      <div class="hero-cta">
        <a href="/demo" class="btn-primary">Спробувати онлайн</a>
        <a href="#features" class="btn-ghost">Дізнатись більше</a>
      </div>
    </div>

    <!-- Намальований лаунчер -->
    <div class="launcher-wrap fade-up fade-delay">
      <div class="launcher">
        <!-- шапка -->
        <div class="lnc-header">
          <div class="lnc-logo-row">
            <div class="lnc-logo">
              <img src="/litopys-logo-launcher.gif" alt="Litopys" class="lnc-logo-img">
            </div>
            <div class="lnc-patch">
              <img src="/shevron.png" alt="Шеврон" class="lnc-shevron-img">
            </div>
          </div>
          <div class="lnc-subtitle-pill">Перший окремий батальйон безпілотних писарів</div>
          <div class="lnc-license-row">
            <div class="lnc-license">
              <span class="lnc-lic-line green">Ліцензія: активна (повна) безстроково</span>
              <span class="lnc-lic-line green">Власник: Litopys.</span>
            </div>
            <button class="lnc-account-btn">Акаунт</button>
          </div>
        </div>
        <!-- кнопки модулів -->
        <div class="lnc-modules">
          <div class="lnc-module">
            <div class="lnc-module-stripe"></div>
            <div class="lnc-module-body">
              <p class="lnc-module-title">Відкрити ЖБД</p>
              <p class="lnc-module-desc">Журнал бойових дій: підготуй,<br/>сформуй, запиши</p>
            </div>
          </div>
          <div class="lnc-module">
            <div class="lnc-module-stripe"></div>
            <div class="lnc-module-body">
              <p class="lnc-module-title">Відкрити ЖОВтР</p>
              <p class="lnc-module-desc">Бойове розпорядження: підготуй,<br/>сформуй, запиши</p>
            </div>
          </div>
        </div>
        <p class="lnc-tagline">Забудь, як тримати ручку в руці!</p>
      </div>
    </div>
  </section>

  <!-- ══ STATS ══ -->
  <section class="section-stats">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-item fade-up">
          <p class="stat-num">4×</p>
          <p class="stat-label">Швидкість</p>
        </div>
        <div class="stat-item fade-up" style="--d:.1s">
          <p class="stat-num">100%</p>
          <p class="stat-label">Офлайн</p>
        </div>
        <div class="stat-item fade-up" style="--d:.2s">
          <p class="stat-num">DOCX</p>
          <p class="stat-label">Сумісний формат</p>
        </div>
        <div class="stat-item fade-up" style="--d:.3s">
          <p class="stat-num">🇺🇦</p>
          <p class="stat-label">Зроблено в Україні</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ ЩО ЦЕ ══ -->
  <section class="section-what">
    <div class="container">
      <div class="what-grid">
        <div class="what-text fade-up">
          <p class="eyebrow">Що це таке</p>
          <h2>Редактор,<br/>зроблений для УПА —<br/>Української Паперової Армії.</h2>
          <p class="body-text">Літопис — настільна програма для Windows, яка дозволяє швидко та легко писати Журнал бойових дій і Журнал відданих та отриманих розпоряджень без мозолів на руках.</p>
          <p class="body-text">Все офлайн. Жодної реєстрації. Відкрив — і одразу до роботи.</p>
          <a href="/demo" class="btn-primary" style="margin-top:2rem;display:inline-block;">Спробувати демо →</a>
        </div>
        <div class="facts-col">
          <div class="fact-card fade-up" style="--d:.05s">
            <div class="fact-icon-wrap">⚡</div>
            <div>
              <p class="fact-title">Миттєвий старт</p>
              <p class="fact-desc">Відкривається за секунди, без реєстрації та налаштувань</p>
            </div>
          </div>
          <div class="fact-card fade-up" style="--d:.1s">
            <div class="fact-icon-wrap">🔒</div>
            <div>
              <p class="fact-title">Ваші дані — ваші</p>
              <p class="fact-desc">Усі файли зберігаються локально, нічого не йде в мережу</p>
            </div>
          </div>
          <div class="fact-card fade-up" style="--d:.15s">
            <div class="fact-icon-wrap">📄</div>
            <div>
              <p class="fact-title">DOCX та PDF</p>
              <p class="fact-desc">Зберігає у Word-форматі, експортує в PDF для друку</p>
            </div>
          </div>
          <div class="fact-card fade-up" style="--d:.2s">
            <div class="fact-icon-wrap">🖨️</div>
            <div>
              <p class="fact-title">Друк одним кліком</p>
              <p class="fact-desc">Прямо з програми, з попереднім переглядом сторінки</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ FEATURES ══ -->
  <section id="features" class="section-features">
    <div class="container">
      <div class="section-header fade-up">
        <p class="eyebrow">Можливості</p>
        <h2>Менше клопоту.<br/>Більше справи.</h2>
        <p class="section-sub">Все що потрібно для роботи з документами — і нічого зайвого.</p>
      </div>
      <div class="features-grid">
        <div class="feature-card fade-up" style="--d:.0s">
          <div class="feature-icon">📋</div>
          <h3>ЖБД</h3>
          <p>Журнал бойових дій з таблицею, датою та часом — заповнюй і друкуй.</p>
        </div>
        <div class="feature-card fade-up" style="--d:.08s">
          <div class="feature-icon">📝</div>
          <h3>ЖОВтР</h3>
          <p>Шаблон журналу з усіма необхідними полями. Готово за хвилини.</p>
        </div>
        <div class="feature-card fade-up" style="--d:.16s">
          <div class="feature-icon">✍️</div>
          <h3>Персональний шрифт</h3>
          <p>Оцифруємо твій почерк — зміни ніхто не помітить.</p>
        </div>
        <div class="feature-card fade-up" style="--d:.0s">
          <div class="feature-icon">🧹</div>
          <h3>Чистий інтерфейс</h3>
          <p>Нічого зайвого. Тільки потрібні поля — без переповнених панелей.</p>
        </div>
        <div class="feature-card fade-up" style="--d:.08s">
          <div class="feature-icon">💾</div>
          <h3>Автозбереження</h3>
          <p>Дані не зникнуть. Файли на вашому диску, під вашим контролем.</p>
        </div>
        <div class="feature-card fade-up" style="--d:.16s">
          <div class="feature-icon">🖥️</div>
          <h3>Повністю офлайн</h3>
          <p>Жодних серверів і підписок. Працює без інтернету в будь-яких умовах.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ CTA ══ -->
  <section class="section-cta">
    <div class="container">
      <div class="cta-card fade-up">
        <p class="eyebrow cta-eyebrow">Готові спробувати?</p>
        <h2>Відкрийте Літопис<br/>прямо зараз</h2>
        <p class="cta-sub">Протестуйте редактор у браузері — без реєстрації та завантажень.</p>
        <a href="/demo" class="btn-white">Відкрити демо →</a>
      </div>
    </div>
  </section>

</Layout>

<style is:global>
  /* ── Fade-up анімація ── */
  .fade-up {
    opacity: 0;
    transform: translateY(32px);
    transition: opacity .65s ease, transform .65s ease;
    transition-delay: var(--d, 0s);
  }
  .fade-up.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .fade-delay { --d: .18s; }
</style>

<style>
  /* ── Tokens ── */
  .container { max-width: 1060px; margin: 0 auto; padding: 0 1.5rem; }
  .eyebrow {
    font-size: .75rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: #4f7cac;
    margin-bottom: 1rem;
  }
  .body-text { color: #4b5563; line-height: 1.8; font-size: 1rem; }
  .body-text + .body-text { margin-top: .75rem; }
  .ua-text { color: inherit; }

  /* ── Buttons ── */
  .btn-primary {
    display: inline-block;
    background: #1a1a2e;
    color: #fff;
    padding: .8rem 1.9rem;
    border-radius: 50px;
    font-size: .9375rem;
    font-weight: 600;
    transition: opacity .2s, transform .2s, box-shadow .2s;
    box-shadow: 0 4px 16px rgba(0,0,0,.2);
  }
  .btn-primary:hover { opacity: .85; transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,.25); }
  .btn-ghost {
    display: inline-block;
    color: #374151;
    padding: .8rem 1.9rem;
    border-radius: 50px;
    font-size: .9375rem;
    font-weight: 500;
    border: 1.5px solid #d1d5db;
    transition: border-color .2s, color .2s, background .2s;
  }
  .btn-ghost:hover { border-color: #1a1a2e; color: #1a1a2e; }
  .btn-white {
    display: inline-block;
    background: #fff;
    color: #1a1a2e;
    padding: .85rem 2.2rem;
    border-radius: 50px;
    font-size: 1rem;
    font-weight: 700;
    transition: transform .2s, box-shadow .2s;
    box-shadow: 0 4px 20px rgba(0,0,0,.18);
  }
  .btn-white:hover { transform: translateY(-2px); box-shadow: 0 10px 32px rgba(0,0,0,.25); }

  /* ── Hero ── */
  .hero {
    position: relative;
    min-height: calc(100vh - 52px);
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 4rem;
    max-width: 1060px;
    margin: 0 auto;
    padding: 5rem 1.5rem 4rem;
    overflow: visible;
  }
  .hero-bg {
    position: fixed;
    inset: 0;
    z-index: -1;
    background: radial-gradient(ellipse at 20% 40%, #dce8f5 0%, transparent 55%),
                radial-gradient(ellipse at 80% 60%, #f5ead8 0%, transparent 50%),
                #f8f9fb;
    pointer-events: none;
  }
  .hero-badge {
    display: inline-block;
    background: rgba(255,255,255,.8);
    color: #4f7cac;
    font-size: .8rem;
    font-weight: 600;
    padding: .35rem 1rem;
    border-radius: 50px;
    border: 1px solid #c9dff0;
    margin-bottom: 1.5rem;
    letter-spacing: .03em;
    backdrop-filter: blur(8px);
  }
  .hero h1 {
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 800;
    letter-spacing: -.04em;
    line-height: 1.07;
    margin-bottom: 1.5rem;
    color: #111827;
  }
  .hero-sub { font-size: 1.0625rem; color: #6b7280; line-height: 1.75; margin-bottom: 2.5rem; }
  .hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; }
  .br-d { display: none; }
  @media (min-width: 640px) { .br-d { display: block; } }

  /* ── Launcher ── */
  .launcher-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    perspective: 1200px;
  }
  .launcher {
    background: #fff;
    border-radius: 20px;
    box-shadow: 0 30px 80px rgba(0,0,0,.12), 0 8px 24px rgba(0,0,0,.06);
    padding: 2rem;
    width: 100%;
    max-width: 440px;
    transform: rotateY(-4deg) rotateX(2deg);
    transition: transform .4s ease, box-shadow .4s ease;
  }
  .launcher:hover {
    transform: rotateY(0deg) rotateX(0deg);
    box-shadow: 0 40px 100px rgba(0,0,0,.15), 0 12px 32px rgba(0,0,0,.08);
  }

  /* лого рядок */
  .lnc-header { display: flex; flex-direction: column; gap: .75rem; margin-bottom: 1.25rem; }
  .lnc-logo-row { display: flex; align-items: center; justify-content: space-between; }
  .lnc-logo { display: flex; align-items: center; gap: .6rem; }
  .lnc-logo-img { height: 52px; width: auto; display: block; }
  .lnc-shevron-img { height: 72px; width: 72px; object-fit: contain; }


  /* підзаголовок */
  .lnc-subtitle-pill {
    display: inline-block;
    border: 1px solid #c8b870;
    color: #6b5a20;
    font-size: .8rem;
    padding: .3rem .9rem;
    border-radius: 20px;
    background: #fdfaf0;
  }

  /* ліцензія */
  .lnc-license-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #f8faf8;
    border: 1px solid #d1e8d1;
    border-radius: 10px;
    padding: .6rem .9rem;
  }
  .lnc-license { display: flex; flex-direction: column; gap: .1rem; }
  .lnc-lic-line { font-size: .75rem; }
  .lnc-lic-line.green { color: #2a7a2a; }
  .lnc-account-btn {
    background: #1a1a2e;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: .4rem 1rem;
    font-size: .8rem;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
  }

  /* модулі */
  .lnc-modules { display: grid; grid-template-columns: 1fr 1fr; gap: .75rem; margin-bottom: 1rem; }
  .lnc-module {
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    overflow: hidden;
    background: #fff;
    transition: box-shadow .2s, transform .2s;
    cursor: pointer;
  }
  .lnc-module:hover { box-shadow: 0 6px 20px rgba(0,0,0,.1); transform: translateY(-2px); }
  .lnc-module-stripe { height: 5px; background: linear-gradient(90deg, #005BBB 50%, #FFD500 50%); }
  .lnc-module-body { padding: 1rem; text-align: center; }
  .lnc-module-title { font-size: 1rem; font-weight: 700; color: #111827; margin-bottom: .35rem; }
  .lnc-module-desc { font-size: .75rem; color: #9ca3af; line-height: 1.5; }

  /* тегляйн */
  .lnc-tagline { text-align: center; font-size: .8rem; color: #9ca3af; }

  /* ── Stats ── */
  .section-stats {
    background: rgba(255,255,255,.7);
    backdrop-filter: blur(12px);
    border-top: 1px solid rgba(255,255,255,.8);
    border-bottom: 1px solid #e5e7eb;
    padding: 3rem 0;
  }
  .stats-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 2rem; text-align: center; }
  .stat-num { font-size: 2rem; font-weight: 800; color: #111827; letter-spacing: -.03em; margin-bottom: .25rem; }
  .stat-label { font-size: .875rem; color: #6b7280; font-weight: 500; }

  /* ── What ── */
  .section-what { padding: 7rem 0; }
  .what-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
  .what-text h2 {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800; letter-spacing: -.03em; line-height: 1.12;
    margin-bottom: 1.25rem; color: #111827;
  }
  .facts-col { display: flex; flex-direction: column; gap: 1rem; }
  .fact-card {
    display: flex; gap: 1rem; align-items: flex-start;
    background: rgba(255,255,255,.8);
    border: 1px solid #e5e7eb; border-radius: 14px; padding: 1.25rem;
    backdrop-filter: blur(8px);
    transition: box-shadow .2s, transform .2s, border-color .2s;
  }
  .fact-card:hover { box-shadow: 0 8px 24px rgba(0,0,0,.08); transform: translateY(-2px); border-color: #bfd4e8; }
  .fact-icon-wrap { font-size: 1.5rem; flex-shrink: 0; margin-top: .1rem; }
  .fact-title { font-weight: 700; font-size: .9375rem; margin-bottom: .2rem; color: #111827; }
  .fact-desc { font-size: .8125rem; color: #6b7280; line-height: 1.55; }

  /* ── Features ── */
  .section-features { padding: 7rem 0; }
  .section-header { text-align: center; margin-bottom: 4rem; }
  .section-header h2 {
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 800; letter-spacing: -.04em; line-height: 1.1; color: #111827; margin-bottom: .75rem;
  }
  .section-sub { font-size: 1.0625rem; color: #6b7280; margin-top: .75rem; }
  .features-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.25rem; }
  .feature-card {
    background: rgba(255,255,255,.85);
    border: 1px solid #e5e7eb; border-radius: 18px; padding: 2rem;
    backdrop-filter: blur(8px);
    transition: box-shadow .2s, transform .2s, border-color .2s;
  }
  .feature-card:hover { box-shadow: 0 12px 32px rgba(0,0,0,.09); transform: translateY(-3px); border-color: #bfd4e8; }
  .feature-icon { font-size: 2rem; margin-bottom: 1.25rem; }
  .feature-card h3 { font-size: 1.0625rem; font-weight: 700; margin-bottom: .6rem; color: #111827; letter-spacing: -.01em; }
  .feature-card p { font-size: .875rem; color: #6b7280; line-height: 1.7; }

  /* ── CTA ── */
  .section-cta { padding: 7rem 0 8rem; }
  .cta-card {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%);
    border-radius: 28px; padding: 5rem 3rem; text-align: center; color: #fff;
    box-shadow: 0 24px 64px rgba(0,0,0,.25);
    position: relative; overflow: hidden;
  }
  .cta-card::before {
    content: '';
    position: absolute;
    top: -80px; right: -80px;
    width: 320px; height: 320px;
    background: radial-gradient(circle, rgba(255,213,0,.12) 0%, transparent 70%);
    pointer-events: none;
  }
  .cta-card::after {
    content: '';
    position: absolute;
    bottom: -60px; left: -60px;
    width: 280px; height: 280px;
    background: radial-gradient(circle, rgba(0,91,187,.2) 0%, transparent 70%);
    pointer-events: none;
  }
  .cta-eyebrow { color: rgba(255,255,255,.5) !important; }
  .cta-card h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800; letter-spacing: -.04em; line-height: 1.1; margin-bottom: 1rem;
    position: relative; z-index: 1;
  }
  .cta-sub { font-size: 1.0625rem; color: rgba(255,255,255,.7); margin-bottom: 2.5rem; line-height: 1.6; position: relative; z-index: 1; }

  /* ── Mobile ── */
  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; min-height: auto; padding-top: 3rem; }
    .launcher-wrap { display: none; }
    .what-grid { grid-template-columns: 1fr; gap: 3rem; }
    .stats-grid { grid-template-columns: repeat(2,1fr); }
  }
  @media (max-width: 640px) {
    .features-grid { grid-template-columns: 1fr; }
    .cta-card { padding: 3rem 1.5rem; }
  }
</style>

<script>
  // Scroll fade-in via IntersectionObserver
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if(e.isIntersecting) {
        e.target.classList.add('visible');
        observer.unobserve(e.target);
      }
    });
  }, { threshold: 0.12 });

  document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
</script>
