---
import Layout from '../layouts/Layout.astro';

const token = Astro.url.searchParams.get('token') ?? '';

let status: 'loading' | 'success' | 'error' | 'expired' | 'used' = 'loading';
let errorMsg = '';

if (!token) {
  status = 'error';
  errorMsg = 'Токен відсутній';
} else {
  try {
    const res = await fetch(`https://api.litopys.win/auth/verify?token=${encodeURIComponent(token)}`);
    const data = await res.json();

    if (data.ok && data.token) {
      Astro.cookies.set('litopys_token', data.token, {
        httpOnly: true,
        secure: true,
        sameSite: 'lax',
        path: '/',
        maxAge: 60 * 60 * 24 * 30,
      });
      return Astro.redirect('/dashboard');
    } else {
      if (data.error === 'token_expired') status = 'expired';
      else if (data.error === 'token_already_used') status = 'used';
      else { status = 'error'; errorMsg = data.error ?? 'Невідома помилка'; }
    }
  } catch {
    status = 'error';
    errorMsg = 'Помилка зʼєднання з сервером';
  }
}
---

<Layout title="Підтвердження email — Літопис">
  <div class="wrap">
    <div class="card">
      <img src="/litopys-logo-launcher.gif" alt="Літопис" class="logo" />

      {status === 'loading' && (
        <div class="state">
          <div class="icon">⏳</div>
          <h1>Перевірка...</h1>
        </div>
      )}

      {status === 'success' && (
        <div class="state">
          <div class="icon">✅</div>
          <h1>Email підтверджено</h1>
          <p class="sub">Перенаправляємо у кабінет...</p>
        </div>
      )}

      {status === 'expired' && (
        <div class="state">
          <div class="icon">⏰</div>
          <h1>Посилання застаріло</h1>
          <p class="sub">Термін дії посилання минув. Зареєструйтесь знову щоб отримати нове.</p>
          <a href="/register" class="btn">Зареєструватись знову</a>
        </div>
      )}

      {status === 'used' && (
        <div class="state">
          <div class="icon">✅</div>
          <h1>Вже підтверджено</h1>
          <p class="sub">Цей email вже було підтверджено раніше.</p>
          <a href="/login" class="btn">Увійти</a>
        </div>
      )}

      {status === 'error' && (
        <div class="state">
          <div class="icon">❌</div>
          <h1>Помилка</h1>
          <p class="sub">{errorMsg}</p>
          <a href="/register" class="btn">Зареєструватись</a>
        </div>
      )}
    </div>
  </div>
</Layout>

<style>
  .wrap {
    min-height: calc(100vh - 52px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
  }
  .card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 20px;
    padding: 2.5rem 2rem;
    width: 100%;
    max-width: 400px;
    box-shadow: 0 8px 32px rgba(0,0,0,.08);
    text-align: center;
  }
  .logo { height: 48px; margin: 0 auto 1.25rem; }
  .state { display: flex; flex-direction: column; align-items: center; gap: .75rem; }
  .icon { font-size: 3rem; }
  h1 { font-size: 1.375rem; font-weight: 800; color: #111827; letter-spacing: -.03em; }
  .sub { font-size: .875rem; color: #6b7280; line-height: 1.6; max-width: 300px; }
  .btn {
    display: inline-block;
    margin-top: .5rem;
    background: #1a1a2e;
    color: #fff;
    border-radius: 10px;
    padding: .65rem 1.5rem;
    font-size: .9rem;
    font-weight: 700;
    transition: opacity .2s;
  }
  .btn:hover { opacity: .85; }
</style>
