---
import Layout from '../layouts/Layout.astro';

if (Astro.cookies.has('litopys_token')) {
  return Astro.redirect('/dashboard');
}

let error = '';
let emailSent = false;
let sentEmail = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const email    = form.get('email')?.toString() ?? '';
  const password = form.get('password')?.toString() ?? '';
  const name     = form.get('name')?.toString() ?? '';

  try {
    const res = await fetch('https://api.litopys.win/auth/register', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ email, password, name }),
    });
    const data = await res.json();

    if (data.ok && data.emailVerificationRequired) {
      emailSent = true;
      sentEmail = email;
    } else {
      const msgs: Record<string, string> = {
        email_already_registered: 'Цей email вже зареєстрований',
        password_too_short: 'Пароль має бути не менше 8 символів',
        'email, password and name are required': 'Заповніть всі поля',
        too_many_requests: 'Забагато спроб. Спробуйте пізніше',
      };
      error = msgs[data.error] ?? 'Помилка реєстрації';
    }
  } catch {
    error = 'Помилка зʼєднання з сервером';
  }
}
---

<Layout title="Реєстрація — Літопис">
  <div class="wrap">
    <div class="card">
      <img src="/litopys-logo-launcher.gif" alt="Літопис" class="logo" />

      {emailSent ? (
        <div class="success-state">
          <div class="mail-icon">📬</div>
          <h1>Перевірте пошту</h1>
          <p class="sub">Лист з посиланням для підтвердження надіслано на</p>
          <p class="sent-email">{sentEmail}</p>
          <p class="hint">Посилання дійсне 24 години. Якщо листа немає — перевірте папку «Спам».</p>
          <a href="/login" class="btn-login">Увійти після підтвердження →</a>
        </div>
      ) : (
        <>
          <h1>Створити акаунт</h1>
          <p class="sub">Після реєстрації підтвердіть email щоб активувати акаунт</p>

          {error && <div class="alert-error">{error}</div>}

          <form method="POST" class="form">
            <label>
              Імʼя
              <input type="text" name="name" required autocomplete="name" placeholder="Іван Петренко" />
            </label>
            <label>
              Email
              <input type="email" name="email" required autocomplete="email" placeholder="user@example.com" />
            </label>
            <label>
              Пароль
              <input type="password" name="password" required autocomplete="new-password" placeholder="Мінімум 8 символів" minlength="8" />
            </label>
            <button type="submit" class="btn-submit">Зареєструватись</button>
          </form>

          <p class="login-link">Вже є акаунт? <a href="/login">Увійти</a></p>
        </>
      )}
    </div>
  </div>
</Layout>

<style>
  .wrap {
    min-height: calc(100vh - 52px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
  }
  .card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 20px;
    padding: 2.5rem 2rem;
    width: 100%;
    max-width: 400px;
    box-shadow: 0 8px 32px rgba(0,0,0,.08);
    text-align: center;
  }
  .logo { height: 48px; margin: 0 auto 1.25rem; }
  h1 { font-size: 1.375rem; font-weight: 800; color: #111827; margin-bottom: .375rem; letter-spacing: -.03em; }
  .sub { font-size: .875rem; color: #6b7280; margin-bottom: 1.75rem; }

  /* Success state */
  .success-state { display: flex; flex-direction: column; align-items: center; gap: .75rem; }
  .mail-icon { font-size: 3rem; margin-bottom: .5rem; }
  .sent-email { font-size: 1rem; font-weight: 700; color: #1a1a2e; background: #f3f4f6; padding: .5rem 1rem; border-radius: 8px; word-break: break-all; }
  .hint { font-size: .8125rem; color: #9ca3af; line-height: 1.6; margin-top: .25rem; }
  .btn-login { display: inline-block; margin-top: .75rem; background: #1a1a2e; color: #fff; border-radius: 10px; padding: .65rem 1.5rem; font-size: .9rem; font-weight: 700; transition: opacity .2s; }
  .btn-login:hover { opacity: .85; }

  /* Form */
  .form { display: flex; flex-direction: column; gap: 1rem; text-align: left; }
  label { display: flex; flex-direction: column; gap: .375rem; font-size: .8125rem; font-weight: 600; color: #374151; }
  input {
    padding: .65rem .9rem;
    border: 1.5px solid #d1d5db;
    border-radius: 10px;
    font-size: .9375rem;
    font-family: inherit;
    outline: none;
    transition: border-color .15s;
  }
  input:focus { border-color: #1a1a2e; }
  .btn-submit {
    margin-top: .5rem;
    background: #1a1a2e;
    color: #fff;
    border: none;
    border-radius: 10px;
    padding: .75rem;
    font-size: .9375rem;
    font-weight: 700;
    cursor: pointer;
    font-family: inherit;
    transition: opacity .2s;
  }
  .btn-submit:hover { opacity: .85; }
  .alert-error {
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #dc2626;
    border-radius: 10px;
    padding: .65rem 1rem;
    font-size: .875rem;
    margin-bottom: 1rem;
    text-align: left;
  }
  .login-link { margin-top: 1.25rem; font-size: .875rem; color: #6b7280; }
  .login-link a { color: #1a1a2e; font-weight: 600; }
</style>
