---
import Layout from '../layouts/Layout.astro';

const token = Astro.url.searchParams.get('token') ?? '';

let status: 'success' | 'error' | 'expired' | 'used' = 'error';
let errorMsg = '';

if (!token) {
  status = 'error';
  errorMsg = 'Токен відсутній';
} else {
  try {
    const res = await fetch(`https://api.litopys.win/confirm-password-change?token=${encodeURIComponent(token)}`);
    const data = await res.json();

    if (data.ok) {
      status = 'success';
    } else if (data.error === 'token_expired') {
      status = 'expired';
    } else if (data.error === 'token_already_used') {
      status = 'used';
    } else {
      status = 'error';
      errorMsg = data.error ?? 'Невідома помилка';
    }
  } catch {
    status = 'error';
    errorMsg = 'Помилка зʼєднання з сервером';
  }
}
---

<Layout title="Підтвердження зміни паролю — Літопис">
  <div class="wrap">
    <div class="card">
      <img src="/litopys-logo-launcher.gif" alt="Літопис" class="logo" />

      {status === 'success' && (
        <div class="state">
          <div class="icon">✅</div>
          <h1>Пароль змінено</h1>
          <p class="sub">Ваш пароль успішно оновлено. Лист-підтвердження надіслано на пошту.</p>
          <a href="/dashboard/security" class="btn">Повернутись до безпеки</a>
        </div>
      )}

      {status === 'expired' && (
        <div class="state">
          <div class="icon">⏰</div>
          <h1>Посилання застаріло</h1>
          <p class="sub">Термін дії посилання минув (1 година). Спробуйте змінити пароль знову.</p>
          <a href="/dashboard/security" class="btn">Змінити пароль</a>
        </div>
      )}

      {status === 'used' && (
        <div class="state">
          <div class="icon">✅</div>
          <h1>Вже підтверджено</h1>
          <p class="sub">Це посилання вже було використано. Пароль змінено раніше.</p>
          <a href="/dashboard" class="btn">До кабінету</a>
        </div>
      )}

      {status === 'error' && (
        <div class="state">
          <div class="icon">❌</div>
          <h1>Помилка</h1>
          <p class="sub">{errorMsg}</p>
          <a href="/dashboard/security" class="btn">Змінити пароль</a>
        </div>
      )}
    </div>
  </div>
</Layout>

<style>
  .wrap {
    min-height: calc(100vh - 52px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
  }
  .card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 20px;
    padding: 2.5rem 2rem;
    width: 100%;
    max-width: 400px;
    box-shadow: 0 8px 32px rgba(0,0,0,.08);
    text-align: center;
  }
  .logo { height: 48px; margin: 0 auto 1.25rem; }
  .state { display: flex; flex-direction: column; align-items: center; gap: .75rem; }
  .icon { font-size: 3rem; }
  h1 { font-size: 1.375rem; font-weight: 800; color: #111827; letter-spacing: -.03em; }
  .sub { font-size: .875rem; color: #6b7280; line-height: 1.6; max-width: 300px; }
  .btn {
    display: inline-block;
    margin-top: .5rem;
    background: #1a1a2e;
    color: #fff;
    border-radius: 10px;
    padding: .65rem 1.5rem;
    font-size: .9rem;
    font-weight: 700;
    transition: opacity .2s;
  }
  .btn:hover { opacity: .85; }
</style>
