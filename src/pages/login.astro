---
import Layout from '../layouts/Layout.astro';

if (Astro.cookies.has('litopys_token')) {
  return Astro.redirect('/dashboard');
}

let error = '';
let mfaRequired = false;
let pendingEmail = '';
let pendingPassword = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const email = form.get('email')?.toString() ?? '';
  const password = form.get('password')?.toString() ?? '';
  const mfaCode = form.get('mfa_code')?.toString() ?? '';
  const isMfaStep = form.get('mfa_step') === '1';

  try {
    const body: Record<string, string> = isMfaStep
      ? { email, password, code: mfaCode }
      : { email, password };

    const res = await fetch('https://api.litopys.win/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    const data = await res.json();

    if (data.ok && data.token) {
      Astro.cookies.set('litopys_token', data.token, {
        httpOnly: true,
        secure: true,
        sameSite: 'lax',
        path: '/',
        maxAge: 60 * 60 * 24 * 30,
      });
      return Astro.redirect('/dashboard');
    } else if (data.mfaRequired) {
      mfaRequired = true;
      pendingEmail = email;
      pendingPassword = password;
    } else {
      const msgs: Record<string, string> = {
        'invalid credentials': 'Невірний email або пароль',
        'too_many_login_attempts': 'Забагато спроб. Спробуйте пізніше',
        'invalid_mfa_code': 'Невірний код MFA',
        'email and password are required': 'Заповніть email і пароль',
      };
      error = msgs[data.error] ?? 'Помилка входу';
    }
  } catch {
    error = 'Помилка зʼєднання з сервером';
  }
}
---

<Layout title="Вхід — Літопис">
  <div class="login-wrap">
    <div class="login-card">
      <img src="/litopys-logo-launcher.gif" alt="Літопис" class="login-logo" />
      <h1>Особистий кабінет</h1>
      <p class="login-sub">Увійдіть, щоб переглянути ліцензію та сесії</p>
      <p class="register-link">Немає акаунту? <a href="/register">Зареєструватись</a></p>

      {error && <div class="alert-error">{error}</div>}

      {!mfaRequired ? (
        <form method="POST" class="login-form">
          <label>
            Email
            <input type="email" name="email" required autocomplete="email" placeholder="user@litopys.pro" />
          </label>
          <label>
            Пароль
            <input type="password" name="password" required autocomplete="current-password" placeholder="••••••••" />
          </label>
          <button type="submit" class="btn-submit">Увійти</button>
        </form>
      ) : (
        <form method="POST" class="login-form">
          <input type="hidden" name="mfa_step" value="1" />
          <input type="hidden" name="email" value={pendingEmail} />
          <input type="hidden" name="password" value={pendingPassword} />
          <p class="mfa-hint">Введіть код з Microsoft Authenticator</p>
          <label>
            Код MFA
            <input type="text" name="mfa_code" required inputmode="numeric" pattern="[0-9]{6}" maxlength="6" placeholder="123456" autofocus />
          </label>
          <button type="submit" class="btn-submit">Підтвердити</button>
        </form>
      )}
    </div>
  </div>
</Layout>

<style>
  .login-wrap {
    min-height: calc(100vh - 52px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem;
  }
  .login-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 20px;
    padding: 2.5rem 2rem;
    width: 100%;
    max-width: 400px;
    box-shadow: 0 8px 32px rgba(0,0,0,.08);
    text-align: center;
  }
  .login-logo { height: 48px; margin: 0 auto 1.25rem; }
  h1 { font-size: 1.375rem; font-weight: 800; color: #111827; margin-bottom: .375rem; letter-spacing: -.03em; }
  .login-sub { font-size: .875rem; color: #6b7280; margin-bottom: 1.75rem; }
  .login-form { display: flex; flex-direction: column; gap: 1rem; text-align: left; }
  label { display: flex; flex-direction: column; gap: .375rem; font-size: .8125rem; font-weight: 600; color: #374151; }
  input {
    padding: .65rem .9rem;
    border: 1.5px solid #d1d5db;
    border-radius: 10px;
    font-size: .9375rem;
    font-family: inherit;
    outline: none;
    transition: border-color .15s;
  }
  input:focus { border-color: #1a1a2e; }
  .btn-submit {
    margin-top: .5rem;
    background: #1a1a2e;
    color: #fff;
    border: none;
    border-radius: 10px;
    padding: .75rem;
    font-size: .9375rem;
    font-weight: 700;
    cursor: pointer;
    font-family: inherit;
    transition: opacity .2s;
  }
  .btn-submit:hover { opacity: .85; }
  .alert-error {
    background: #fef2f2;
    border: 1px solid #fecaca;
    color: #dc2626;
    border-radius: 10px;
    padding: .65rem 1rem;
    font-size: .875rem;
    margin-bottom: 1rem;
    text-align: left;
  }
  .mfa-hint { font-size: .875rem; color: #6b7280; margin-bottom: .5rem; }
  .register-link { font-size: .875rem; color: #6b7280; margin-bottom: 1.5rem; }
  .register-link a { color: #1a1a2e; font-weight: 600; }
</style>
