---
import Layout from '../../layouts/Layout.astro';

const { user, license } = Astro.locals;

const moduleLabels: Record<string, string> = {
  jbd: 'ЖБД',
  br: 'ЖОВтР',
};

const licenseTypeLabels: Record<string, string> = {
  full: 'Повна',
  jbd: 'ЖБД',
  br: 'ЖОВтР',
  trial: 'Пробна',
};

const expiresDate = license ? new Date(license.expiresAt) : null;
const now = new Date();
const daysLeft = expiresDate ? Math.ceil((expiresDate.getTime() - now.getTime()) / (1000 * 60 * 60 * 24)) : null;
const isExpiringSoon = daysLeft !== null && daysLeft <= 14 && daysLeft > 0;
---

<Layout title="Кабінет — Літопис">
  <div class="dash-wrap">
    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-logo">
        <img src="/litopys-logo-launcher.gif" alt="Літопис" />
      </div>
      <nav class="sidebar-nav">
        <a href="/dashboard" class="nav-item active">
          <span class="nav-icon">🪪</span> Ліцензія
        </a>
        <a href="/dashboard/licenses" class="nav-item">
          <span class="nav-icon-svg"><img src="/icon-key.svg" alt="" /></span> Ліцензія
        </a>
        <a href="/dashboard/security" class="nav-item">
          <span class="nav-icon">🔐</span> Безпека
        </a>
      </nav>
      <form method="POST" action="/api/logout" class="sidebar-logout">
        <button type="submit" class="logout-btn">Вийти</button>
      </form>
    </aside>

    <!-- Main -->
    <main class="dash-main">
      <div class="dash-header">
        <div>
          <p class="dash-greeting">Вітаємо, {user?.name}!</p>
          <p class="dash-email">{user?.email}</p>
        </div>
      </div>

      <!-- License card -->
      {license ? (
        <section class="card">
          <div class="card-header">
            <h2>Ліцензія</h2>
            <span class:list={['badge', license.active ? 'badge-green' : 'badge-red']}>
              {license.active ? 'Активна' : 'Неактивна'}
            </span>
          </div>
          <div class="info-grid">
            <div class="info-item">
              <p class="info-label">Тип</p>
              <p class="info-value">{licenseTypeLabels[license.type] ?? license.type}</p>
            </div>
            <div class="info-item">
              <p class="info-label">Модулі</p>
              <p class="info-value">{license.modules.map(m => moduleLabels[m] ?? m).join(', ')}</p>
            </div>
            <div class="info-item">
              <p class="info-label">Макс. сесій</p>
              <p class="info-value">{license.maxSessions}</p>
            </div>
            <div class="info-item">
              <p class="info-label">Діє до</p>
              <p class:list={['info-value', isExpiringSoon && 'text-warning']}>
                {expiresDate?.toLocaleDateString('uk-UA', { day: 'numeric', month: 'long', year: 'numeric' })}
                {daysLeft !== null && daysLeft > 0 && ` (${daysLeft} дн.)`}
                {daysLeft !== null && daysLeft <= 0 && ' — Закінчилась'}
              </p>
            </div>
          </div>
          {isExpiringSoon && (
            <div class="alert-warning">
              Термін ліцензії закінчується менш ніж через 14 днів. Зверніться до адміністратора для продовження.
            </div>
          )}
        </section>
      ) : (
        <section class="card">
          <p class="no-license">Ліцензії не знайдено. Зверніться до адміністратора.</p>
        </section>
      )}

      {user?.role === 'admin' && (
        <section class="card card-small">
          <div class="card-header">
            <h2>Двофакторна автентифікація</h2>
            <span class:list={['badge', user?.mfaEnabled ? 'badge-green' : 'badge-gray']}>
              {user?.mfaEnabled ? 'Увімкнено' : 'Вимкнено'}
            </span>
          </div>
          <p class="card-desc">
            {user?.mfaEnabled
              ? 'Ваш акаунт захищений кодом з Microsoft Authenticator.'
              : 'Увімкніть MFA для додаткового захисту акаунту.'}
          </p>
          <a href="/dashboard/security" class="btn-outline">Керувати безпекою →</a>
        </section>
      )}
    </main>
  </div>
</Layout>

<style>
  .dash-wrap {
    display: grid;
    grid-template-columns: 220px 1fr;
    min-height: calc(100vh - 52px);
  }

  /* Sidebar */
  .sidebar {
    border-right: 1px solid #e5e7eb;
    padding: 1.5rem 1rem;
    display: flex;
    flex-direction: column;
    background: #fafafa;
  }
  .sidebar-logo img { height: 36px; margin-bottom: 2rem; }
  .sidebar-nav { display: flex; flex-direction: column; gap: .25rem; flex: 1; }
  .nav-item {
    display: flex;
    align-items: center;
    gap: .6rem;
    padding: .6rem .85rem;
    border-radius: 10px;
    font-size: .875rem;
    font-weight: 500;
    color: #374151;
    transition: background .15s, color .15s;
  }
  .nav-item:hover { background: #f3f4f6; color: #111827; }
  .nav-item.active { background: #1a1a2e; color: #fff; }
  .nav-icon { font-size: 1rem; }
  .nav-icon-svg img { width: 16px; height: 16px; display: block; filter: brightness(0) saturate(100%); }
  .nav-item.active .nav-icon-svg img { filter: brightness(0) invert(1); }
  .sidebar-logout { margin-top: 1rem; }
  .logout-btn {
    width: 100%;
    background: none;
    border: 1.5px solid #e5e7eb;
    border-radius: 10px;
    padding: .55rem;
    font-size: .8125rem;
    color: #6b7280;
    cursor: pointer;
    font-family: inherit;
    transition: border-color .15s, color .15s;
  }
  .logout-btn:hover { border-color: #dc2626; color: #dc2626; }

  /* Main */
  .dash-main { padding: 2rem 2.5rem; max-width: 720px; }
  .dash-header { margin-bottom: 2rem; }
  .dash-greeting { font-size: 1.25rem; font-weight: 800; color: #111827; letter-spacing: -.02em; }
  .dash-email { font-size: .875rem; color: #6b7280; margin-top: .2rem; }

  /* Cards */
  .card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 16px;
    padding: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .card-small { }
  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }
  .card-header h2 { font-size: 1rem; font-weight: 700; color: #111827; }
  .card-desc { font-size: .875rem; color: #6b7280; margin-bottom: 1rem; line-height: 1.6; }

  /* Badge */
  .badge {
    font-size: .75rem;
    font-weight: 700;
    padding: .25rem .65rem;
    border-radius: 20px;
  }
  .badge-green { background: #dcfce7; color: #15803d; }
  .badge-red { background: #fef2f2; color: #dc2626; }
  .badge-gray { background: #f3f4f6; color: #6b7280; }

  /* Info grid */
  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .info-label { font-size: .75rem; font-weight: 600; color: #9ca3af; text-transform: uppercase; letter-spacing: .05em; margin-bottom: .25rem; }
  .info-value { font-size: .9375rem; font-weight: 600; color: #111827; }
  .text-warning { color: #d97706; }

  /* Alerts */
  .alert-warning {
    margin-top: 1.25rem;
    background: #fffbeb;
    border: 1px solid #fde68a;
    color: #92400e;
    border-radius: 10px;
    padding: .75rem 1rem;
    font-size: .8125rem;
    line-height: 1.6;
  }

  .no-license { color: #6b7280; font-size: .9375rem; }

  .btn-outline {
    display: inline-block;
    border: 1.5px solid #1a1a2e;
    color: #1a1a2e;
    border-radius: 8px;
    padding: .5rem 1.1rem;
    font-size: .875rem;
    font-weight: 600;
    transition: background .15s, color .15s;
  }
  .btn-outline:hover { background: #1a1a2e; color: #fff; }

  @media (max-width: 700px) {
    .dash-wrap { grid-template-columns: 1fr; }
    .sidebar { flex-direction: row; flex-wrap: wrap; border-right: none; border-bottom: 1px solid #e5e7eb; padding: 1rem; }
    .sidebar-logo { display: none; }
    .sidebar-nav { flex-direction: row; }
    .sidebar-logout { margin-top: 0; margin-left: auto; }
    .dash-main { padding: 1.25rem 1rem; }
    .info-grid { grid-template-columns: 1fr; }
  }
</style>
