---
import Layout from '../../layouts/Layout.astro';

const { user } = Astro.locals;
const token = Astro.cookies.get('litopys_token')?.value ?? '';

let sessions: any[] = [];
let maxSessions = 0;
let actionError = '';
let actionSuccess = '';

// Дія: завершити сеанс (revoke) через POST форму
if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const sessionId = form.get('sessionId')?.toString();
  const action = form.get('action')?.toString();

  if (sessionId && action === 'revoke') {
    try {
      const res = await fetch(`https://api.litopys.win/sessions/${sessionId}/revoke`, {
        method: 'PATCH',
        headers: { Authorization: `Bearer ${token}` },
      });
      const data = await res.json();
      if (data.ok) {
        actionSuccess = 'Сеанс завершено';
      } else {
        actionError = 'Не вдалось завершити сеанс';
      }
    } catch {
      actionError = 'Помилка зʼєднання';
    }
  }
}

// Завантажуємо сеанси
try {
  const res = await fetch('https://api.litopys.win/sessions', {
    headers: { Authorization: `Bearer ${token}` },
  });
  const data = await res.json();
  if (data.ok) {
    sessions = data.sessions ?? [];
    maxSessions = data.maxSessions ?? 0;
  }
} catch {}
---

<Layout title="Сеанси — Літопис">
  <div class="dash-wrap">
    <aside class="sidebar">
      <div class="sidebar-logo">
        <img src="/litopys-logo-launcher.gif" alt="Літопис" />
      </div>
      <nav class="sidebar-nav">
        <a href="/dashboard" class="nav-item">
          <span class="nav-icon">🪪</span> Ліцензія
        </a>
        <a href="/dashboard/sessions" class="nav-item active">
          <span class="nav-icon">💻</span> Сеанси
        </a>
        <a href="/dashboard/security" class="nav-item">
          <span class="nav-icon">🔐</span> Безпека
        </a>
      </nav>
      <form method="POST" action="/api/logout" class="sidebar-logout">
        <button type="submit" class="logout-btn">Вийти</button>
      </form>
    </aside>

    <main class="dash-main">
      <div class="dash-header">
        <div>
          <p class="dash-greeting">Сеанси застосунку</p>
          <p class="dash-email">{user?.name} · {user?.email}</p>
        </div>
      </div>

      {actionSuccess && <div class="alert-success">{actionSuccess}</div>}
      {actionError && <div class="alert-error">{actionError}</div>}

      <section class="card">
        <div class="card-header">
          <h2>Активні сеанси</h2>
          <span class="badge badge-gray">{sessions.length} / {maxSessions}</span>
        </div>

        {sessions.length === 0 ? (
          <p class="no-sessions">Активних сеансів немає.</p>
        ) : (
          <div class="sessions-list">
            {sessions.map((s: any) => (
              <div class="session-item">
                <div class="session-info">
                  <div class="session-icon">💻</div>
                  <div>
                    <p class="session-name">{s.session_name ?? s.sessionName ?? 'Без назви'}</p>
                    <p class="session-device">{s.current_device_label ?? s.currentDeviceLabel ?? '—'}</p>
                    <p class="session-last">
                      Остання активність:{' '}
                      {s.last_seen_at
                        ? new Date(s.last_seen_at).toLocaleString('uk-UA', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' })
                        : '—'}
                    </p>
                  </div>
                </div>
                <form method="POST" class="revoke-form">
                  <input type="hidden" name="action" value="revoke" />
                  <input type="hidden" name="sessionId" value={s.id} />
                  <button type="submit" class="btn-revoke"
                    onclick="return confirm('Завершити цей сеанс?')">
                    Завершити
                  </button>
                </form>
              </div>
            ))}
          </div>
        )}
      </section>

      <section class="card card-info">
        <p class="info-text">
          💡 Сеанс — це запущений застосунок Литопис на конкретному пристрої. Якщо ви бачите незнайомий сеанс — завершіть його.
        </p>
      </section>
    </main>
  </div>
</Layout>

<style>
  .dash-wrap { display: grid; grid-template-columns: 220px 1fr; min-height: calc(100vh - 52px); }
  .sidebar { border-right: 1px solid #e5e7eb; padding: 1.5rem 1rem; display: flex; flex-direction: column; background: #fafafa; }
  .sidebar-logo img { height: 36px; margin-bottom: 2rem; }
  .sidebar-nav { display: flex; flex-direction: column; gap: .25rem; flex: 1; }
  .nav-item { display: flex; align-items: center; gap: .6rem; padding: .6rem .85rem; border-radius: 10px; font-size: .875rem; font-weight: 500; color: #374151; transition: background .15s, color .15s; }
  .nav-item:hover { background: #f3f4f6; color: #111827; }
  .nav-item.active { background: #1a1a2e; color: #fff; }
  .nav-icon { font-size: 1rem; }
  .sidebar-logout { margin-top: 1rem; }
  .logout-btn { width: 100%; background: none; border: 1.5px solid #e5e7eb; border-radius: 10px; padding: .55rem; font-size: .8125rem; color: #6b7280; cursor: pointer; font-family: inherit; transition: border-color .15s, color .15s; }
  .logout-btn:hover { border-color: #dc2626; color: #dc2626; }

  .dash-main { padding: 2rem 2.5rem; max-width: 720px; }
  .dash-header { margin-bottom: 2rem; }
  .dash-greeting { font-size: 1.25rem; font-weight: 800; color: #111827; letter-spacing: -.02em; }
  .dash-email { font-size: .875rem; color: #6b7280; margin-top: .2rem; }

  .card { background: #fff; border: 1px solid #e5e7eb; border-radius: 16px; padding: 1.5rem; margin-bottom: 1.25rem; }
  .card-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem; }
  .card-header h2 { font-size: 1rem; font-weight: 700; color: #111827; }
  .badge { font-size: .75rem; font-weight: 700; padding: .25rem .65rem; border-radius: 20px; }
  .badge-gray { background: #f3f4f6; color: #6b7280; }

  .sessions-list { display: flex; flex-direction: column; gap: .75rem; }
  .session-item { display: flex; align-items: center; justify-content: space-between; padding: 1rem; background: #f9fafb; border: 1px solid #e5e7eb; border-radius: 12px; gap: 1rem; }
  .session-info { display: flex; align-items: flex-start; gap: .875rem; }
  .session-icon { font-size: 1.75rem; flex-shrink: 0; margin-top: .1rem; }
  .session-name { font-size: .9375rem; font-weight: 700; color: #111827; margin-bottom: .15rem; }
  .session-device { font-size: .8125rem; color: #6b7280; margin-bottom: .15rem; }
  .session-last { font-size: .75rem; color: #9ca3af; }

  .revoke-form { flex-shrink: 0; }
  .btn-revoke { background: none; border: 1.5px solid #fca5a5; color: #dc2626; border-radius: 8px; padding: .45rem .9rem; font-size: .8125rem; font-weight: 600; cursor: pointer; font-family: inherit; transition: background .15s, color .15s; white-space: nowrap; }
  .btn-revoke:hover { background: #fef2f2; }

  .no-sessions { color: #6b7280; font-size: .9375rem; }

  .card-info { background: #f0f9ff; border-color: #bae6fd; }
  .info-text { font-size: .875rem; color: #0369a1; line-height: 1.65; }

  .alert-success { background: #f0fdf4; border: 1px solid #bbf7d0; color: #15803d; border-radius: 10px; padding: .65rem 1rem; font-size: .875rem; margin-bottom: 1rem; }
  .alert-error { background: #fef2f2; border: 1px solid #fecaca; color: #dc2626; border-radius: 10px; padding: .65rem 1rem; font-size: .875rem; margin-bottom: 1rem; }

  @media (max-width: 700px) {
    .dash-wrap { grid-template-columns: 1fr; }
    .sidebar { flex-direction: row; flex-wrap: wrap; border-right: none; border-bottom: 1px solid #e5e7eb; padding: 1rem; }
    .sidebar-logo { display: none; }
    .sidebar-nav { flex-direction: row; }
    .sidebar-logout { margin-top: 0; margin-left: auto; }
    .dash-main { padding: 1.25rem 1rem; }
    .session-item { flex-direction: column; align-items: flex-start; }
  }
</style>
