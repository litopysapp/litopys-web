<script>
// ══════════════════════════════════════════════════════
//  Стан — точно як DEFAULT_BLANK_TEMPLATE та DEFAULT_CALIBRATION у застосунку
// ══════════════════════════════════════════════════════
const blank = {
  header1: 'Дата',
  header2: 'Зміст розпорядження',
  header3: 'Примітка',
  nums: '1,2,3',
  innerMargin: 10,   // мм від краю аркуша до таблиці
  top: 20,           // мм зверху аркуша де починається таблиця
  bottom: 287,       // мм зверху аркуша де закінчується таблиця
  dateWidth: 30,     // мм
  textWidth: 120,    // мм
  noteWidth: 25,     // мм
  rows: 44,          // загальна кількість рядків
  headerRows: 2,     // рядків шапки
  lineWidth: 0.25,   // мм товщина ліній
};

const cal = {
  gridOpacity: 0.42,
  oddDateX: 0.5,
  oddTimeX: 0.5,
  oddTextX: 0.5,
  firstRowTop: 31.47,
  rowHeight: 6.084,
  textFontSize: 24,
  letterRotate: 0,
  useHandFont: true,
};

// Формат: { date, time, text, note }
// date і time виводяться окремими рядками в колонці "Дата"
const sampleRows = [
  {
    date: '24.02.2022', time: '03:40',
    text: 'Повномасштабне вторгнення почалося близько 3:40, коли на територію Луганської області зайшла перша колона російських танків',
    note: ''
  },
  {
    date: '24.02.2022', time: '04:00',
    text: 'Близько 4:00 за київським часом (UTC+2) 24 лютого президент рф вовапітун оголосив про воєнну операцію з метою нібито «демілітаризації та денацифікації України».',
    note: ''
  },
  {
    date: '06.07.2023', time: '02:50',
    text: 'Російські війська підірвали Каховську ГЕС. Підрив призвів до неконтрольованого витоку води з Каховського водосховища, що в свою чергу спричинило до катастрофічного підняття рівня води та затоплення населених пунктів нижче Каховського водосховища.',
    note: ''
  },
];

function $(id){ return document.getElementById(id); }

// ── Синхронізація firstRowTop і rowHeight з blank.rows/bottom (як syncTextFlowToBlankRows) ──
function syncCalFromBlank(){
  const textRows = Math.max(1, blank.rows - blank.headerRows);
  cal.rowHeight = (blank.bottom - blank.top) / blank.rows;
  cal.firstRowTop = blank.bottom - textRows * cal.rowHeight;
  // оновлюємо відповідні елементи лівої панелі
  const rh = $('rowHeight'); if(rh){ rh.value = cal.rowHeight.toFixed(3); const v=$('rowHeightVal'); if(v) v.textContent=cal.rowHeight.toFixed(3); }
  const ft = $('firstRowTop'); if(ft){ ft.value = cal.firstRowTop.toFixed(2); const v=$('firstRowTopVal'); if(v) v.textContent=cal.firstRowTop.toFixed(2); }
}

// ── Таблиця: побудова бланк-шару (лінії, заголовки, нумери) ──
function buildBlankLayer(){
  const L = blank.innerMargin;            // tableLeft мм
  const T = blank.top;
  const B = blank.bottom;
  const H = B - T;
  const DW = blank.dateWidth;
  const TW = blank.textWidth;
  const NW = blank.noteWidth;
  const W = DW + TW + NW;
  const ROW_H = H / blank.rows;
  const lw = blank.lineWidth;
  const HR = Math.max(1, Math.round(blank.headerRows));
  const nums = blank.nums.split(',').map(s=>s.trim());
  const op = cal.gridOpacity;

  let html = `<div style="position:absolute;inset:0;opacity:${op};">`;

  // Зовнішня рамка
  html += `<div class="tpl-border" style="left:${L}mm;top:${T}mm;width:${W}mm;height:${H}mm;border-width:${lw}mm;"></div>`;

  // Вертикальні лінії
  html += `<div class="tpl-vline" style="left:${L+DW}mm;top:${T}mm;height:${H}mm;border-left-width:${lw}mm;"></div>`;
  html += `<div class="tpl-vline" style="left:${L+DW+TW}mm;top:${T}mm;height:${H}mm;border-left-width:${lw}mm;"></div>`;

  // Горизонтальні лінії рядків (після шапки)
  for(let r = HR; r < blank.rows; r++){
    const y = T + r * ROW_H;
    html += `<div class="tpl-hline" style="left:${L}mm;top:${y}mm;width:${W}mm;border-top-width:${lw}mm;"></div>`;
  }

  // Лінія під шапкою (між заголовками і номерами, якщо headerRows=2)
  if(HR >= 2){
    const y = T + (HR-1)*ROW_H;
    html += `<div class="tpl-hline" style="left:${L}mm;top:${y}mm;width:${W}mm;border-top-width:${lw}mm;"></div>`;
  }

  // Заголовки колонок (верхній рядок шапки)
  html += `<div class="tpl-header" style="left:${L}mm;top:${T}mm;width:${DW}mm;height:${(HR-1)*ROW_H}mm;">${blank.header1}</div>`;
  html += `<div class="tpl-header" style="left:${L+DW}mm;top:${T}mm;width:${TW}mm;height:${(HR-1)*ROW_H}mm;">${blank.header2}</div>`;
  html += `<div class="tpl-header" style="left:${L+DW+TW}mm;top:${T}mm;width:${NW}mm;height:${(HR-1)*ROW_H}mm;">${blank.header3}</div>`;

  // Номери колонок (нижній рядок шапки)
  const numY = T + (HR-1)*ROW_H;
  html += `<div class="tpl-num" style="left:${L}mm;top:${numY}mm;width:${DW}mm;height:${ROW_H}mm;">${nums[0]||'1'}</div>`;
  html += `<div class="tpl-num" style="left:${L+DW}mm;top:${numY}mm;width:${TW}mm;height:${ROW_H}mm;">${nums[1]||'2'}</div>`;
  html += `<div class="tpl-num" style="left:${L+DW+TW}mm;top:${numY}mm;width:${NW}mm;height:${ROW_H}mm;">${nums[2]||'3'}</div>`;

  html += `</div>`;
  $('jbd-blank-layer').innerHTML = html;
}

// ── Розбиття тексту по рядках таблиці ──
// Повертає масив рядків — скільки поміщається у кожному рядку
// Використовує Canvas для вимірювання ширини тексту
function splitTextIntoRows(text, fontStr, fontSizePt, colWidthMm) {
  if(!text) return [];
  // Конвертуємо мм → px (96dpi: 1mm = 3.7795px)
  const PX_PER_MM = 3.7795;
  const maxPx = colWidthMm * PX_PER_MM;
  const fontSizePx = fontSizePt * (96/72);

  // Canvas для вимірювання
  const cv = document.createElement('canvas');
  const ctx = cv.getContext('2d');
  ctx.font = `${fontSizePx}px ${fontStr}`;

  const words = text.split(' ');
  const lines = [];
  let current = '';

  for(const word of words){
    const test = current ? current + ' ' + word : word;
    if(ctx.measureText(test).width <= maxPx){
      current = test;
    } else {
      if(current) lines.push(current);
      current = word;
    }
  }
  if(current) lines.push(current);
  return lines;
}

// ── Текст-шар (зразкові дані) ──
function buildTextLayer(){
  const L  = blank.innerMargin;
  const DW = blank.dateWidth;
  const TW = blank.textWidth;
  const NW = blank.noteWidth;
  const ROW_H = (blank.bottom - blank.top) / blank.rows;
  const HR = Math.max(1, Math.round(blank.headerRows));

  const font = cal.useHandFont
    ? 'OleksiiFull,Times New Roman,Times,serif'
    : 'Times New Roman,Times,serif';
  const fs   = cal.textFontSize + 'pt';
  const fsPx = cal.textFontSize * (96/72);

  const fontStr = font.replace(/,/g,', ');

  // Будуємо список рядків таблиці з розбиттям тексту
  // Колонка "Дата": перший рядок = дата (відступ oddDateX),
  //                 другий рядок = час (відступ oddTimeX),
  //                 далі порожньо
  // Колонка "Текст": рядки тексту з переносом
  const tableRows = [];

  sampleRows.forEach(row => {
    const dateStr = row.date || '';
    const timeStr = row.time || '';
    const textLines = splitTextIntoRows(row.text||'', fontStr, cal.textFontSize, TW - cal.oddTextX - 1);
    const noteLines = splitTextIntoRows(row.note||'', fontStr, cal.textFontSize, NW - 1.5);

    // Колонка дати: дата на 1-му рядку, час на 2-му, решта порожньо
    const dateCol = [];
    if(dateStr) dateCol.push({ val: dateStr, xOff: cal.oddDateX });
    if(timeStr) dateCol.push({ val: timeStr, xOff: cal.oddTimeX });

    const maxLines = Math.max(dateCol.length, textLines.length, noteLines.length, 1);
    for(let l = 0; l < maxLines; l++){
      tableRows.push({
        dateCell: dateCol[l] || null,   // { val, xOff } або null
        text:     textLines[l] || '',
        note:     noteLines[l] || '',
      });
    }
  });

  let html = '';
  tableRows.forEach((row, i) => {
    const rowIndex = HR + i;
    const rowTop   = blank.top + rowIndex * ROW_H;
    if(rowTop >= blank.bottom) return;

    const rowBottom = rowTop + ROW_H;
    const base = `position:absolute;box-sizing:border-box;`
      + `font-family:${font};font-size:${fs};line-height:1;`
      + `overflow:hidden;white-space:nowrap;`
      + `bottom:${(297 - rowBottom - 2.73).toFixed(3)}mm;`;

    if(row.dateCell){
      const xOff = row.dateCell.xOff;
      html += `<div style="${base}left:${(L+xOff).toFixed(2)}mm;width:${(DW-xOff-0.5).toFixed(2)}mm;">${esc(row.dateCell.val)}</div>`;
    }
    if(row.text) html += `<div style="${base}left:${(L+DW+cal.oddTextX).toFixed(2)}mm;width:${(TW-cal.oddTextX-0.5).toFixed(2)}mm;">${esc(row.text)}</div>`;
    if(row.note) html += `<div style="${base}left:${(L+DW+TW+0.5).toFixed(2)}mm;width:${(NW-1).toFixed(2)}mm;">${esc(row.note)}</div>`;
  });

  $('jbd-text-layer').innerHTML = html;
}

function esc(s){ return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

function render(){
  syncCalFromBlank();
  buildBlankLayer();
  buildTextLayer();
}

// ── Масштабування ──
function scalePreview(){
  const preview = $('preview');
  const area = document.querySelector('.preview-area');
  if(!preview || !area) return;
  const scale = Math.min((area.clientHeight-20)/1123, (area.clientWidth-20)/794, 1);
  preview.style.transform = `scale(${scale})`;
  preview.style.transformOrigin = 'top center';
}

// ── Прив'язка бігунків лівої панелі ──
function bindLeft(id, key, decimals){
  const el = $(id); if(!el) return;
  const val = $(id+'Val')||$(id+'Value');
  el.addEventListener('input', ()=>{
    cal[key] = parseFloat(el.value);
    if(val) val.textContent = parseFloat(el.value).toFixed(decimals||2);
    render();
  });
}
bindLeft('gridOpacity','gridOpacity',2);
bindLeft('oddDateX','oddDateX',1);
bindLeft('oddTimeX','oddTimeX',1);
bindLeft('oddTextX','oddTextX',1);
// rowHeight і firstRowTop — тільки для читання (обраховуються з blank)

// ── Прив'язка бігунків правої панелі ──
function bindRight(id, key, isText){
  const el = $(id); if(!el) return;
  const val = $(id+'Val')||($(id+'Value'));
  el.addEventListener('input', ()=>{
    if(isText){ blank[key] = el.value; }
    else { blank[key] = parseFloat(el.value); }
    if(val && !isText) val.textContent = parseFloat(el.value).toFixed(2);
    render();
    // доступно рядків для тексту
    const ti = $('blankTextRowsInfo');
    if(ti) ti.value = Math.max(0, blank.rows - blank.headerRows);
  });
}

bindRight('blankHeader1','header1',true);
bindRight('blankHeader2','header2',true);
bindRight('blankHeader3','header3',true);
bindRight('blankInnerMargin','innerMargin');
bindRight('blankTop','top');
bindRight('blankBottom','bottom');
bindRight('blankDateWidth','dateWidth');
bindRight('blankTextWidth','textWidth');
bindRight('blankNoteWidth','noteWidth');
bindRight('blankRows','rows');
bindRight('blankHeaderRows','headerRows');
bindRight('blankLineWidth','lineWidth');

// Рукопис
const textFontSizeEl = $('textFontSize');
if(textFontSizeEl){
  textFontSizeEl.addEventListener('input', ()=>{
    cal.textFontSize = parseFloat(textFontSizeEl.value);
    const v=$('textFontSizeVal'); if(v) v.textContent=textFontSizeEl.value;
    render();
  });
}
const letterRotateEl = $('letterRotate');
if(letterRotateEl){
  letterRotateEl.addEventListener('input', ()=>{
    cal.letterRotate = parseFloat(letterRotateEl.value);
    const v=$('letterRotateVal'); if(v) v.textContent=letterRotateEl.value;
    render();
  });
}
const useHandFontEl = $('useHandFont');
if(useHandFontEl){
  useHandFontEl.addEventListener('change', ()=>{
    cal.useHandFont = useHandFontEl.checked;
    render();
  });
}

// Range → span для всіх інших
document.querySelectorAll('input[type=range]').forEach(inp=>{
  const span=$(inp.id+'Val')||$(inp.id+'Value');
  if(span && !span.textContent) span.textContent=inp.value;
  // Не перепризначаємо — вже прив'язано вище
});

// Dropdown toggles
$('btn-twm').addEventListener('click', e=>{ e.stopPropagation(); $('textWorkMenu').classList.toggle('open'); });
$('btn-menu').addEventListener('click', e=>{ e.stopPropagation(); $('profileMenu').classList.toggle('open'); });
document.addEventListener('click', ()=>{ $('textWorkMenu').classList.remove('open'); $('profileMenu').classList.remove('open'); });
$('btn-undo').addEventListener('click', ()=>{});
$('btn-redo').addEventListener('click', ()=>{});

// ── Перший рендер ──
render();
scalePreview();
window.addEventListener('resize', scalePreview);

// ── DOCX export ──
$('btn-export-docx').addEventListener('click', async ()=>{
  const { Document, Packer, Paragraph, TextRun, Table, TableRow, TableCell, WidthType, BorderStyle } = await import('https://esm.sh/docx@8.5.0');
  const { saveAs } = await import('https://esm.sh/file-saver@2.0.5');

  const sz = Math.max(1, Math.round(blank.lineWidth * 8));
  const border = { style: BorderStyle.SINGLE, size: sz, color: '000000' };
  const cb = { top:border, bottom:border, left:border, right:border };

  const totalW = blank.dateWidth + blank.textWidth + blank.noteWidth;
  const widths = [
    Math.round(blank.dateWidth/totalW*100*50),
    Math.round(blank.textWidth/totalW*100*50),
    Math.round(blank.noteWidth/totalW*100*50),
  ];

  const mkCell = (text, bold) => new TableCell({
    children:[new Paragraph({children:[new TextRun({text:text||'',bold:!!bold})]})],
    borders:cb, width:{size:widths[0], type:WidthType.DXA},
  });

  const headerRow = new TableRow({ children:[
    new TableCell({children:[new Paragraph({children:[new TextRun({text:blank.header1,bold:true})]})], borders:cb}),
    new TableCell({children:[new Paragraph({children:[new TextRun({text:blank.header2,bold:true})]})], borders:cb}),
    new TableCell({children:[new Paragraph({children:[new TextRun({text:blank.header3,bold:true})]})], borders:cb}),
  ]});

  const dataRows = [];
  for(let i=0; i<blank.rows - blank.headerRows; i++){
    const r = sampleRows[i]||{};
    dataRows.push(new TableRow({ children:[
      new TableCell({children:[new Paragraph({children:[new TextRun({text:(r.date||'').replace(/\n/g,' ')})]})], borders:cb}),
      new TableCell({children:[new Paragraph({children:[new TextRun({text:r.text||''})]})], borders:cb}),
      new TableCell({children:[new Paragraph({children:[new TextRun({text:r.note||''})]})], borders:cb}),
    ]}));
  }

  const doc = new Document({ sections:[{ children:[
    new Table({ rows:[headerRow,...dataRows], width:{size:100,type:WidthType.PERCENTAGE} })
  ]}]});

  const blob = await Packer.toBlob(doc);
  saveAs(blob,'litopys-jbd-demo.docx');
});
</script>