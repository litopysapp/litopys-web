---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Демо редактора — Літопис" description="Спробуйте Літопис прямо в браузері." fullPage={true}>

<div class="demo-root">

  <!-- ═══ TOPBAR ═══ -->
  <header class="app-topbar">
    <div class="app-title">
      <a href="/" class="brand-logo-link">
        <img src="/litopys-logo-demo.gif" alt="Літопис демо" class="brand-logo-img">
      </a>
    </div>

    <div class="litopys-module-switch locked">
      <span class="litopys-module-switch-label active-label">ЖБД</span>
      <button type="button" class="litopys-module-switch-toggle" title="Доступно у повній версії">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#3c3c3c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="12" r="3"/><rect width="20" height="14" x="2" y="5" rx="7"/></svg>
      </button>
      <span class="litopys-module-switch-label">БР</span>
    </div>

    <div class="controls topbar-actions">
      <!-- Undo/Redo -->
      <div class="document-history-actions">
        <button id="btn-undo" class="icon-only" title="Скасувати">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 14 4 9l5-5"/><path d="M4 9h10.5a5.5 5.5 0 0 1 0 11H11"/></svg>
        </button>
        <button id="btn-redo" class="icon-only" title="Повторити">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 14 5-5-5-5"/><path d="M20 9H9.5a5.5 5.5 0 0 0 0 11H13"/></svg>
        </button>
      </div>
      <div class="topbar-sep"></div>

      <!-- "Робота з текстом" -->
      <div class="text-work-menu" id="twm-wrap">
        <button class="manual-text-import-button" id="btn-twm">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 21h8"/><path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"/></svg>
          <span>Робота з текстом</span>
          <span class="dropdown-caret">▾</span>
        </button>
        <div id="textWorkMenu" class="compact-dropdown">
          <div class="compact-dropdown-label">Доступно у повній версії</div>
          <button disabled style="opacity:.45;cursor:default;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M8 12h8M12 8v8"/></svg>
            <span>Вставити текст</span>
          </button>
          <button disabled style="opacity:.45;cursor:default;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4z"/></svg>
            <span>Внести правки</span>
          </button>
        </div>
      </div>

      <!-- DOCX pill -->
      <button id="btn-export-docx" class="file-picker-pill" title="Завантажити DOCX">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        <span class="file-picker-name">DOCX</span>
      </button>

      <!-- Зберегти / Друк (декор) -->
      <button class="icon-only" title="Зберегти PDF (повна версія)">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15.2 3a2 2 0 0 1 1.4.6l3.8 3.8a2 2 0 0 1 .6 1.4V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/><path d="M17 21v-7a1 1 0 0 0-1-1H8a1 1 0 0 0-1 1v7"/><path d="M7 3v4a1 1 0 0 0 1 1h7"/></svg>
      </button>
      <button class="icon-only" title="Друк (повна версія)">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><path d="M6 9V3a1 1 0 0 1 1-1h10a1 1 0 0 1 1 1v6"/><rect x="6" y="14" width="12" height="8" rx="1"/></svg>
      </button>
    </div>

    <div class="topbar-profile">
      <button class="icon-only menu-button" id="btn-menu" title="Меню">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 5h16"/><path d="M4 12h16"/><path d="M4 19h16"/></svg>
      </button>
      <div id="profileMenu" class="profile-menu">
        <div class="compact-dropdown-label">Демо-версія</div>
        <a href="/" class="pmenu-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
          <span>На головну</span>
        </a>
        <a href="/" class="pmenu-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
          <span>Про Літопис</span>
        </a>
      </div>
    </div>
  </header>

  <!-- ═══ APP SHELL — три колонки як у JBD ═══ -->
  <div class="app-shell">

    <!-- Ліва панель — Налаштування -->
    <aside class="settings-panel" id="left-panel">
      <h2>
        <span class="panel-title-text">Налаштування</span>
        <span class="panel-menu-icon" id="btn-collapse-left" title="Згорнути панель">☰</span>
      </h2>

      <div class="settings-block">
        <h3>Preview / PDF</h3>
        <label class="template-toggle">
          <input type="checkbox" id="showGrid" checked>
          Показати бланк у preview
        </label>
        <label>
          Прозорість сітки
          <input type="range" id="gridOpacity" min="0" max="1" step="0.01" value="0.42">
          <span id="gridOpacityValue">0.42</span>
        </label>
        <label class="template-toggle">
          <input type="checkbox" id="hideText">
          Приховати текст
        </label>
      </div>

      <div class="settings-block">
        <h3>Непарні сторінки</h3>
        <label>
          Випадковий відступ дати, мм
          <input type="range" id="oddDateX" min="0" max="40" step="0.1" value="0.5">
          <span id="oddDateXVal">0.5</span>
        </label>
        <label>
          Випадковий відступ часу, мм
          <input type="range" id="oddTimeX" min="0" max="40" step="0.1" value="0.5">
          <span id="oddTimeXVal">0.5</span>
        </label>
        <label>
          Відступ тексту від лівої межі стовпчика, мм
          <input type="range" id="oddTextX" min="0" max="80" step="0.1" value="0.5">
          <span id="oddTextXVal">0.5</span>
        </label>
      </div>

      <div class="settings-block">
        <h3>Рядки</h3>
        <label>
          Верх першого рядка, мм
          <input type="range" id="firstRowTop" min="15" max="35" step="0.01" value="31.47">
          <span id="firstRowTopVal">31.47</span>
        </label>
        <label>
          Крок рядків, мм
          <input type="range" id="rowHeight" min="2.5" max="6.5" step="0.001" value="6.084">
          <span id="rowHeightVal">6.084</span>
        </label>
      </div>

      <div class="settings-block">
        <h3>Початок генерації</h3>
        <label>
          Починати з типу сторінки
          <select id="startPageNumber">
            <option value="1">1 — непарна</option>
            <option value="2">2 — парна</option>
          </select>
        </label>
        <label>
          Початковий рядок на першій сторінці
          <input type="number" id="startRowNumber" min="1" max="60" step="1" value="1">
        </label>
      </div>

      <div class="settings-block">
        <h3>Рукопис</h3>
        <label class="template-toggle">
          <input type="checkbox" id="useHandFont" checked>
          Рукописний шрифт OleksiiFull
        </label>
        <label>
          Розмір тексту, pt
          <input type="range" id="textFontSize" min="6" max="48" step="0.5" value="24">
          <span id="textFontSizeVal">24</span>
        </label>
        <label>
          Нахил літер, ±°
          <input type="range" id="letterRotate" min="0" max="5" step="0.1" value="0">
          <span id="letterRotateVal">0</span>
        </label>
      </div>

      <div class="settings-actions">
        <button class="icon-only" title="Зберегти налаштування">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15.2 3a2 2 0 0 1 1.4.6l3.8 3.8a2 2 0 0 1 .6 1.4V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/><path d="M17 21v-7a1 1 0 0 0-1-1H8a1 1 0 0 0-1 1v7"/><path d="M7 3v4a1 1 0 0 0 1 1h7"/></svg>
        </button>
        <button class="icon-only" title="Скинути налаштування">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
        </button>
      </div>
    </aside>

    <!-- Центр — аркуш з таблицею ЖБД -->
    <main class="preview-area">
      <div id="preview">
        <div class="page-wrapper">
          <div class="page-abs">

            <!-- Бланк і текст ЖБД — абсолютні мм-координати як у застосунку -->
            <div id="jbd-blank-layer"></div>
            <div id="jbd-text-layer"></div>

          </div><!-- /page-abs -->
        </div>
      </div>
    </main>

    <!-- Права панель — Редактор бланка -->
    <aside class="blank-editor-panel" id="right-panel">
      <h2>
        <span class="panel-title-text">Редактор бланка</span>
        <span class="panel-menu-icon" id="btn-collapse-right" title="Згорнути панель">☰</span>
      </h2>

      <div class="settings-block">
        <h3>Блок: заголовки</h3>
        <label>
          Заголовок колонки 1
          <input type="text" id="blankHeader1" value="Дата">
        </label>
        <label>
          Заголовок колонки 2
          <input type="text" id="blankHeader2" value="Зміст розпорядження">
        </label>
        <label>
          Заголовок колонки 3
          <input type="text" id="blankHeader3" value="Примітка">
        </label>
        <label>
          Номери колонок
          <input type="text" id="blankNums" value="1,2,3">
        </label>
        <label>
          Висота шапки (1–3 рядки)
          <input type="range" id="blankHeaderRows" min="1" max="3" step="1" value="2">
          <span id="blankHeaderRowsVal">2</span>
        </label>
      </div>

      <div class="settings-block">
        <h3>Блок: позиція таблиці</h3>
        <label>
          Внутрішній відступ від краю, мм
          <input type="range" id="blankInnerMargin" min="0" max="30" step="0.1" value="10">
          <span id="blankInnerMarginVal">10</span>
        </label>
        <label>
          Верх таблиці, мм
          <input type="range" id="blankTop" min="5" max="35" step="0.1" value="20">
          <span id="blankTopVal">20</span>
        </label>
        <label>
          Низ таблиці, мм
          <input type="range" id="blankBottom" min="250" max="295" step="0.1" value="287">
          <span id="blankBottomVal">287</span>
        </label>
        <label>
          Фактичний X: непарна / парна
          <input type="text" id="blankActualX" value="25.0 мм / 10.0 мм" readonly>
        </label>
      </div>

      <div class="settings-block">
        <h3>Блок: колонки і рядки</h3>
        <label>
          Ширина колонки 1, мм
          <input type="range" id="blankDateWidth" min="15" max="60" step="0.1" value="30">
          <span id="blankDateWidthVal">30</span>
        </label>
        <label>
          Ширина колонки 2, мм
          <input type="range" id="blankTextWidth" min="80" max="150" step="0.1" value="120">
          <span id="blankTextWidthVal">120</span>
        </label>
        <label>
          Ширина колонки 3, мм
          <input type="range" id="blankNoteWidth" min="15" max="50" step="0.1" value="25">
          <span id="blankNoteWidthVal">25</span>
        </label>
        <label>
          Загальна кількість рядків таблиці
          <input type="range" id="blankRows" min="40" max="55" step="1" value="44">
          <span id="blankRowsVal">44</span>
        </label>
        <label>
          Доступно рядків для тексту
          <input type="text" id="blankTextRowsInfo" value="42" readonly>
        </label>
      </div>

      <div class="settings-block">
        <h3>Блок: експорт і профілі</h3>
        <label>
          Товщина ліній
          <input type="range" id="blankLineWidth" min="0.1" max="0.8" step="0.05" value="0.25">
          <span id="blankLineWidthVal">0.25</span>
        </label>
        <div class="settings-actions" style="margin-top:10px;padding-top:10px;">
          <button class="icon-only" title="Згенерувати PDF-бланк (повна версія)">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          </button>
          <button class="icon-only" title="Зберегти профіль бланка (повна версія)">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15.2 3a2 2 0 0 1 1.4.6l3.8 3.8a2 2 0 0 1 .6 1.4V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/><path d="M17 21v-7H7v7"/><path d="M7 3v4h7"/></svg>
          </button>
          <button class="icon-only" title="Скинути бланк (повна версія)">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
          </button>
        </div>
      </div>
    </aside>

  </div><!-- /app-shell -->

  <!-- Status bar -->
  <div class="status-bar">
    <span class="status-note">Браузерна демо-версія Літопису — деякі функції доступні лише у повній програмі</span>
    <span style="flex:1"></span>
    <a href="/" class="status-link">Дізнатись більше →</a>
  </div>

</div><!-- /demo-root -->
</Layout>

<style is:global>
  @font-face {
    font-family: 'OleksiiFull';
    src: url('/fonts/OleksiiFull-Regular.otf') format('opentype');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  :root { --letter-rotate: 0deg; }

  /* Нахил літер рукопису */
  #jbd-tbody td {
    font-style: oblique var(--letter-rotate);
  }

  /* ── Root ── */
  * { box-sizing: border-box; margin: 0; padding: 0; }

  .demo-root {
    display: flex; flex-direction: column;
    height: 100%;
    background: #f0f2f5;
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Helvetica Neue", Arial, sans-serif;
    font-size: 13px;
    -webkit-font-smoothing: antialiased;
  }

  /* ── TOPBAR ── */
  .app-topbar {
    display: flex; align-items: center; gap: 6px; flex-shrink: 0;
    padding: 8px 14px; margin-bottom: 0;
    background: rgba(255,255,255,.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid #e2e8f0;
    box-shadow: 0 2px 8px rgba(15,23,42,.07);
    flex-wrap: wrap; min-height: 56px;
    position: relative; z-index: 100;
  }
  .app-title { display: flex; align-items: center; gap: 7px; flex-shrink: 0; }
  .brand-logo-link { display: flex; align-items: center; text-decoration: none; }
  .brand-logo-img { height: 32px; width: auto; display: block; }
  .demo-chip {
    font-size: 9px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em;
    color: #64748b; background: #f1f5f9; border: 1px solid #e2e8f0;
    border-radius: 4px; padding: 2px 5px;
  }
  .litopys-module-switch { display: inline-flex; align-items: center; gap: 8px; margin-left: 10px; flex-shrink: 0; }
  .litopys-module-switch-label { font-weight: 700; font-size: 15px; color: #94a3b8; user-select: none; }
  .litopys-module-switch-label.active-label { color: #0f172a; }
  .litopys-module-switch-toggle {
    width: 30px; height: 30px; display: inline-flex; align-items: center; justify-content: center;
    border: 0 !important; background: transparent !important; padding: 0 !important;
    cursor: default !important; box-shadow: none !important; opacity: .5; border-radius: 0 !important;
  }
  .controls { display: flex; align-items: center; gap: 4px; flex-wrap: wrap; }
  .topbar-actions { flex: 1; }
  .topbar-sep { width: 1px; height: 20px; background: #e2e8f0; margin: 0 3px; flex-shrink: 0; }
  .document-history-actions { display: flex; gap: 2px; }

  /* Icon-only */
  button.icon-only {
    width: 34px !important; min-width: 34px !important; height: 34px !important;
    padding: 0 !important; display: inline-flex !important;
    align-items: center !important; justify-content: center !important;
    border: 1px solid transparent !important; border-radius: 8px !important;
    background: transparent !important; color: #334155 !important;
    box-shadow: none !important; cursor: pointer; font-weight: normal !important;
    transition: background .1s, border-color .1s !important; transform: none !important;
  }
  button.icon-only:hover {
    background: #f1f5f9 !important; border-color: #e2e8f0 !important; transform: none !important;
  }

  /* "Робота з текстом" */
  .text-work-menu { position: relative; }
  .manual-text-import-button {
    height: 34px !important; padding: 0 11px !important;
    display: inline-flex !important; align-items: center !important; gap: 6px !important;
    border-radius: 9px !important; border: 1px solid #2f2f2f !important;
    background: #3c3c3c !important; color: #fff !important;
    font-size: 12.5px !important; font-weight: 600 !important; font-family: inherit !important;
    white-space: nowrap !important; cursor: pointer;
    box-shadow: 0 3px 10px rgba(15,23,42,.18) !important;
    transform: none !important; transition: background .12s !important;
  }
  .manual-text-import-button:hover { background: #4a4a4a !important; transform: none !important; }
  .dropdown-caret { font-size: 10px; opacity: .8; }

  /* File picker pill */
  .file-picker-pill {
    display: inline-flex; align-items: center; gap: 6px;
    height: 34px; padding: 0 11px;
    border: 1px solid #cbd5e1 !important; border-radius: 9px !important;
    background: #fff !important; color: #334155 !important;
    font-size: 12.5px; font-weight: 500; font-family: inherit; cursor: pointer;
    box-shadow: 0 1px 4px rgba(15,23,42,.06) !important;
    transform: none !important; transition: background .1s !important;
  }
  .file-picker-pill:hover { background: #f8fafc !important; transform: none !important; }
  .file-picker-name { font-size: 12.5px; }

  /* Compact dropdown */
  .compact-dropdown {
    display: none; position: absolute; top: calc(100% + 7px); left: 0;
    min-width: 200px; background: #fff; border: 1px solid #e2e8f0;
    border-radius: 13px; box-shadow: 0 14px 40px rgba(15,23,42,.15);
    padding: 6px; z-index: 500;
  }
  .compact-dropdown.open { display: block; }
  .compact-dropdown-label {
    padding: 6px 9px 3px; font-size: 10px; font-weight: 700;
    color: #64748b; text-transform: uppercase; letter-spacing: .05em;
  }
  .compact-dropdown button {
    width: 100% !important; text-align: left !important;
    display: flex !important; align-items: center !important; gap: 7px !important;
    padding: 7px 9px !important; border-radius: 8px !important;
    background: transparent !important; color: #334155 !important;
    font-size: 12.5px !important; font-weight: 500 !important; font-family: inherit !important;
    border: 1px solid transparent !important; box-shadow: none !important;
    cursor: pointer !important; transform: none !important;
  }

  /* Profile menu */
  .topbar-profile { margin-left: auto; position: relative; }
  .profile-menu {
    display: none; position: absolute; right: 0; top: calc(100% + 8px);
    min-width: 180px; background: #fff; border: 1px solid #e2e8f0;
    border-radius: 13px; box-shadow: 0 16px 40px rgba(15,23,42,.16);
    padding: 7px; z-index: 3000;
  }
